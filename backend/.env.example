# PII Proxy Architecture - Environment Variables
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env

# Cloud LLM API keys (needed for cloud model routing)
ANTHROPIC_API_KEY=sk-ant-change-me

# Optional: OpenAI (proxy works without it, but OpenAI models will be unavailable)
# OPENAI_API_KEY=sk-change-me

# PostgreSQL password (required in both modes)
POSTGRES_PASSWORD=pii_secure_password

# Ollama cloud instance (local model for PII-sensitive requests)
OLLAMA_API_BASE=https://ollama.example.com
OLLAMA_API_KEY=change-me

# Optional: Slack alerting
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# PII rerouting switch: "true" = reroute PII requests to local model,
# "false" = detect & log PII but pass through to the original model
PII_REROUTE_ENABLED=true

# ---------------------------------------------------------------------------
# Deployment mode: standalone (default) vs integrated
# ---------------------------------------------------------------------------
# Set to "true" to reuse external postgres/redis instead of starting local ones.
# Leave unset to auto-detect based on running containers.
# PII_INTEGRATED=true

# External stack settings (only needed for integrated mode)
# EXTERNAL_NETWORK=homelab_default
# EXTERNAL_POSTGRES_CONTAINER=postgres
# EXTERNAL_REDIS_CONTAINER=redis

# ---------------------------------------------------------------------------
# Database / Redis connection overrides
# ---------------------------------------------------------------------------
# Standalone defaults: pii-postgres-db / pii_user / pii_proxy_db / pii-redis-cache
# Integrated defaults: $EXTERNAL_POSTGRES_CONTAINER / postgres / postgres / $EXTERNAL_REDIS_CONTAINER
#
# PII_DB_HOST=pii-postgres-db
# PII_DB_USER=pii_user
# PII_DB_NAME=pii_proxy_db
# PII_DB_PORT=5432
# PII_REDIS_HOST=pii-redis-cache
# PII_REDIS_PORT=6379
